<UserControl x:Class="vCamService.App.Views.StatusBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="#CCCCCC" BorderThickness="0,1,0,0" Background="#F0F0F0" Padding="8,4">
        <StackPanel Orientation="Horizontal">
            <TextBlock Text="vCam: " FontWeight="SemiBold" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding VCamDeviceName}" Margin="0,0,12,0" VerticalAlignment="Center"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            <TextBlock Text="Active: " FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ActiveStream.Name, FallbackValue='None', TargetNullValue='None'}"
                       Margin="0,0,12,0" VerticalAlignment="Center"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            <TextBlock Text="CPU: " FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CpuPercent, StringFormat={}{0:F1}%}"
                       Margin="0,0,12,0" VerticalAlignment="Center"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            <TextBlock Text="RAM: " FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding RamMb, StringFormat={}{0} MB}"
                       Margin="0,0,12,0" VerticalAlignment="Center"/>

            <Separator Style="{StaticResource {x:Static ToolBar.SeparatorStyleKey}}" Margin="4,0"/>

            <TextBlock Text="FPS: " FontWeight="SemiBold" Margin="4,0,0,0" VerticalAlignment="Center"/>
            <TextBlock Text="{Binding CurrentFps, StringFormat={}{0:F1}}" VerticalAlignment="Center"/>
        </StackPanel>
    </Border>
</UserControl>
