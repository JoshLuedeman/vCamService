<Window x:Class="vCamService.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:vCamService.App.ViewModels"
        xmlns:conv="clr-namespace:vCamService.App.Converters"
        xmlns:views="clr-namespace:vCamService.App.Views"
        Title="vCamService"
        Height="600" Width="900"
        MinHeight="400" MinWidth="640">

    <Window.Resources>
        <conv:StatusToColorConverter x:Key="StatusColorConverter"/>
        <Style x:Key="StreamListItem" TargetType="ListViewItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── Main content ── -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" MinWidth="160"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left panel: stream list + actions ── -->
            <DockPanel Grid.Column="0" LastChildFill="True">

                <!-- Buttons dock to bottom -->
                <Border DockPanel.Dock="Bottom"
                        BorderBrush="#CCCCCC" BorderThickness="0,1,0,0"
                        Padding="4,6">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Add"
                                Command="{Binding AddStreamCommand}"
                                Width="55" Margin="0,0,4,0"/>
                        <Button Content="Remove"
                                Command="{Binding RemoveStreamCommand}"
                                Width="62" Margin="0,0,4,0"/>
                        <Button Content="Set Active"
                                Command="{Binding SetActiveStreamCommand}"
                                Width="80"/>
                    </StackPanel>
                </Border>

                <!-- Stream list fills remaining space -->
                <ListView ItemsSource="{Binding Streams}"
                          SelectedItem="{Binding SelectedStream, Mode=TwoWay}"
                          ItemContainerStyle="{StaticResource StreamListItem}"
                          BorderThickness="0,0,1,0"
                          BorderBrush="#DDDDDD">
                    <ListView.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:StreamItemViewModel}">
                            <StackPanel Orientation="Horizontal" Margin="4,3">
                                <Ellipse Width="10" Height="10"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         Fill="{Binding Status,
                                                Converter={StaticResource StatusColorConverter}}"/>
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"
                                           FontSize="13"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </DockPanel>

            <!-- ── GridSplitter ── -->
            <GridSplitter Grid.Column="1"
                          Width="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="#E0E0E0"
                          ShowsPreview="True"/>

            <!-- ── Right panel: live preview ── -->
            <views:PreviewControl x:Name="Preview" Grid.Column="2"/>
        </Grid>

        <!-- ── Status bar ── -->
        <views:StatusBar Grid.Row="1"/>
    </Grid>
</Window>
