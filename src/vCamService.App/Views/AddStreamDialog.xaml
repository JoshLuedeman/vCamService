<Window x:Class="vCamService.App.Views.AddStreamDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Stream"
        Height="390" Width="420"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        ResizeMode="NoResize">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Form fields -->
        <StackPanel Grid.Row="0">
            <Label Content="Name:" Padding="0,0,0,2"/>
            <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"/>

            <Label Content="URL (rtsp:// or http://):" Padding="0,0,0,2"/>
            <TextBox Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10"/>

            <Label Content="Protocol:" Padding="0,0,0,2"/>
            <ComboBox ItemsSource="{Binding ProtocolOptions}"
                      SelectedValue="{Binding Protocol}"
                      Margin="0,0,0,10"/>

            <Label Content="RTSP Transport:" Padding="0,0,0,2"/>
            <ComboBox ItemsSource="{Binding TransportOptions}"
                      SelectedValue="{Binding RtspTransport}"
                      Margin="0,0,0,10"/>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,4,0">
                    <Label Content="Width:" Padding="0,0,0,2"/>
                    <TextBox Text="{Binding Width, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="4,0">
                    <Label Content="Height:" Padding="0,0,0,2"/>
                    <TextBox Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="4,0,0,0">
                    <Label Content="FPS:" Padding="0,0,0,2"/>
                    <TextBox Text="{Binding Fps, UpdateSourceTrigger=PropertyChanged}"/>
                </StackPanel>
            </Grid>
        </StackPanel>

        <!-- Buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,12,0,0">
            <Button Content="OK"
                    IsDefault="True"
                    IsEnabled="{Binding IsValid}"
                    Click="OnOkClick"
                    Width="75"
                    Margin="0,0,8,0"/>
            <Button Content="Cancel"
                    IsCancel="True"
                    Width="75"/>
        </StackPanel>
    </Grid>
</Window>
