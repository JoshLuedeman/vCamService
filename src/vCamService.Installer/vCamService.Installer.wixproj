<Project Sdk="WixToolset.Sdk/7.0.0">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
    <AcceptEula>wix7</AcceptEula>
    <IconPath Condition="'$(IconPath)' == ''">$(MSBuildThisFileDirectory)..\vCamService.App\Resources\camera.ico</IconPath>
    <DefineConstants>PublishDir=$(PublishDir);FfmpegPath=$(FfmpegPath);ProductVersion=$(ProductVersion);IconPath=$(IconPath)</DefineConstants>
  </PropertyGroup>
</Project>
