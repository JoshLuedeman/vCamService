<Project Sdk="WixToolset.Sdk/7.0.0">
  <PropertyGroup>
    <OutputType>Package</OutputType>
    <InstallerPlatform>x64</InstallerPlatform>
    <AcceptEula>wix7</AcceptEula>
    <DefineConstants>PublishDir=$(PublishDir);FfmpegPath=$(FfmpegPath);ProductVersion=$(ProductVersion)</DefineConstants>
  </PropertyGroup>
</Project>
